# --- Doozy server environment ---
# Copy to .env for local dev. On Render, set these in the dashboard.

# MongoDB connection string (MongoDB Atlas)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/doozy?retryWrites=true&w=majority

# Port the API listens on (Render injects its own PORT)
PORT=4000

# Simple single-password gate. If unset, the API is open (dev only).
# Set a strong value in production so your public subdomain stays private.
APP_PASSWORD=change-me

# Textbelt paid API key — used to send SMS reminders.
# Get yours at https://textbelt.com . Leave blank to disable sending.
TEXTBELT_KEY=

# Phone number reminders are sent to (E.164-ish, e.g. +15551234567)
REMINDER_PHONE=+15551234567

# Comma-separated list of allowed frontend origins for CORS.
# e.g. https://doozy.andrewfbutler.com,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# IANA timezone used for "daily" task resets and scheduled reminders.
TZ=America/Denver

# --- Web Push (VAPID) ---
# Generate a pair with:  npx web-push generate-vapid-keys
# The PUBLIC key is also exposed to the client via /api/push/public-key.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI required by the push spec (your email or site).
VAPID_SUBJECT=mailto:abutler911@gmail.com
